{
  "name": "__PROJECT_SLUG__",
  "version": "0.1.0",
  "private": true,
  "description": "__PITCH__",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:push": "pnpm --filter @__PROJECT_SLUG__/db push",
    "db:studio": "pnpm --filter @__PROJECT_SLUG__/db studio",
    "db:generate": "pnpm --filter @__PROJECT_SLUG__/db generate",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
