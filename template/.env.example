# Copy this file to .env.local and paste real values.
# scaffoldo never sees real secrets — they only live on disk on your machine
# and in your hosting provider's env settings.

# -- Database (Supabase Postgres) -----------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# -- Auth (Clerk) ---------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboarding"

# -- Payments (Stripe) ----------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# -- Email (Resend) -------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="hello@example.com"

# -- Cache + ratelimit (Upstash Redis) ------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -- Vector search (Pinecone) ---------------------------------------------
PINECONE_API_KEY=""
PINECONE_INDEX=""
OPENAI_API_KEY=""

# -- Analytics (PostHog) --------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# -- Errors (Sentry) ------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
