packages/email          # Resend
packages/analytics      # PostHog
packages/observability  # Sentry + pino
packages/cache          # Upstash + ratelimit
packages/ai             # Pinecone
packages/i18n           # next-intl
packages/ui             # shadcn/ui
packages/core           # shared types + errors
packages/config         # eslint / tsconfig / tailwind presets
